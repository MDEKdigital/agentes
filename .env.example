# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis
REDIS_URL=redis://localhost:6379

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://your-evolution-host/
EVOLUTION_API_KEY=your-evolution-api-key

# LLM Providers (fallback global — tenants configuram os seus no painel)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AI...

# App
API_PORT=3001
# URL pública da API (para registrar webhooks na Evolution API — não usar localhost em produção)
PUBLIC_API_URL=http://localhost:3001
WEBHOOK_SECRET=your-random-secret-min-32-chars
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_ENCRYPTION_KEY=your-64-char-hex-key-here

# Next.js (frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:3001
