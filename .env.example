# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
# Evolution API
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# LLM Providers (fallback global — tenants configuram os seus no dashboard)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_AI_API_KEY=your-google-key

# Chave OpenAI usada como fallback para embeddings quando a org não tem chave própria
PLATFORM_OPENAI_EMBEDDING_KEY=

# App
API_PORT=3001
HEALTH_PORT=3001
PUBLIC_API_URL=https://your-api-domain.easypanel.host
SECRET_ENCRYPTION_KEY=your-32-byte-hex-key
WEBHOOK_SECRET=your-webhook-secret
