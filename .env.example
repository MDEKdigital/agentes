# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password
# Evolution API
EVOLUTION_API_URL=https://your-evolution-host/
EVOLUTION_API_KEY=your-evolution-api-key

# LLM Providers (fallback global — tenants configuram os seus no dashboard)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_AI_API_KEY=your-google-key

# App
API_PORT=3001
# URL pública da API (usada para registrar webhooks na Evolution API — NÃO usar localhost em produção)
PUBLIC_API_URL=http://localhost:3001
WEBHOOK_SECRET=your-webhook-secret
# Chave de criptografia AES-256 para secrets das organizações (64 chars hex = 32 bytes)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_ENCRYPTION_KEY=your-64-char-hex-key-here
